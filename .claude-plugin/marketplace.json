{
  "name": "qqbot-mcp",
  "owner": {
    "name": "fuzhibo",
    "email": ""
  },
  "metadata": {
    "description": "QQ Bot MCP integration for Claude Code - send messages, files, and receive tasks from QQ",
    "version": "1.25.1"
  },
  "plugins": [
    {
      "name": "qqbot-mcp",
      "source": "./",
      "description": "QQ Bot MCP integration - bidirectional communication between Claude Code and QQ",
      "version": "1.25.1",
      "author": {
        "name": "fuzhibo"
      },
      "homepage": "https://github.com/fuzhibo/qqbot-claudecode-skill",
      "repository": "https://github.com/fuzhibo/qqbot-claudecode-skill",
      "license": "MIT",
      "keywords": [
        "qq",
        "bot",
        "mcp",
        "messaging",
        "chinese",
        "communication"
      ],
      "category": "communication",
      "commands": [
        "./commands/"
      ],
      "mcpServers": {
        "qqbot": {
          "command": "node",
          "args": [
            "${CLAUDE_PLUGIN_ROOT}/dist/mcp/index.js"
          ],
          "env": {
            "QQBOT_APP_ID": "${QQBOT_APP_ID}",
            "QQBOT_CLIENT_SECRET": "${QQBOT_CLIENT_SECRET}",
            "QQBOT_IMAGE_SERVER_BASE_URL": "${QQBOT_IMAGE_SERVER_BASE_URL}",
            "QQBOT_CHANNEL_MODE": "${QQBOT_CHANNEL_MODE:-auto}"
          }
        }
      },
      "hooks": {
        "SessionStart": [
          {
            "matcher": ".*",
            "hooks": [
              {
                "type": "command",
                "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/check-channel-support.js 2>/dev/null || echo '\\n⚠️  QQ Bot: Channel 模式不可用，已回退到 MCP Tools 模式\\n'"
              },
              {
                "type": "command",
                "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/setup-wizard.js --check 2>/dev/null || echo '\\n🤖 QQ Bot MCP: 尚未配置，请运行 /qqbot-setup 或设置 QQBOT_APP_ID/QQBOT_CLIENT_SECRET 环境变量\\n'"
              },
              {
                "type": "command",
                "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/qqbot-upgrade.js 2>/dev/null || true"
              },
              {
                "type": "command",
                "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/session-start-handler.js 2>/dev/null || true"
              }
            ]
          }
        ],
        "SessionEnd": [
          {
            "matcher": ".*",
            "hooks": [
              {
                "type": "command",
                "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/session-end-handler.js 2>/dev/null || true"
              }
            ]
          }
        ],
        "PostToolUse": [
          {
            "matcher": ".*",
            "hooks": [
              {
                "type": "command",
                "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/qqbot-hook-handler.js PostToolUse 2>/dev/null || true"
              }
            ]
          }
        ],
        "UserPromptSubmit": [
          {
            "matcher": ".*",
            "hooks": [
              {
                "type": "command",
                "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/qqbot-hook-handler.js UserPromptSubmit 2>/dev/null || true"
              }
            ]
          }
        ]
      }
    }
  ]
}
