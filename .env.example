# QQ Bot MCP 环境变量配置
# 复制此文件为 .env 并填入你的实际值
# ⚠️ 注意：.env 文件包含敏感信息，请勿提交到 Git！

# QQ 机器人 AppID
QQBOT_APP_ID=your-app-id-here

# QQ 机器人 Client Secret
QQBOT_CLIENT_SECRET=your-client-secret-here

# 图床服务器地址（可选）
QQBOT_IMAGE_SERVER_BASE_URL=http://your-server:18765

# 测试目标 ID（可选，用于集成测试）
# 格式：G_群号 或 U_用户ID 或 C_频道ID
QQBOT_TEST_TARGET_ID=G_123456789
