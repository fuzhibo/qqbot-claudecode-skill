{
  "name": "@sliverp/qqbot-mcp",
  "version": "1.2.9",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "qqbot": "./bin/qqbot-cli.js",
    "qqbot-mcp": "./dist/src/mcp/index.js",
    "qqbot-mcp-cli": "./bin/qqbot-mcp-cli.js",
    "qqbot-gateway": "./scripts/qqbot-gateway.js",
    "qqbot-hooks": "./scripts/qqbot-hooks.js"
  },
  "files": [
    "dist",
    "bin",
    "src",
    "scripts",
    "skills",
    "commands",
    ".claude-plugin",
    "plugin.json",
    "index.ts",
    "tsconfig.json",
    "openclaw.plugin.json",
    "clawdbot.plugin.json",
    "moltbot.plugin.json",
    "SKILLS.md",
    "README.md"
  ],
  "clawdbot": {
    "extensions": [
      "./index.ts"
    ]
  },
  "moltbot": {
    "extensions": [
      "./index.ts"
    ]
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "bash tests/run-tests.sh",
    "test:local": "bash tests/e2e.sh",
    "test:mcp": "node tests/mcp-integration-test.js",
    "prepack": "npm install --omit=dev",
    "prepare": "npm run build",
    "mcp": "node dist/src/mcp/index.js",
    "doctor": "node scripts/doctor.js",
    "release": "node scripts/build-release.js",
    "release:patch": "node scripts/build-release.js patch",
    "release:minor": "node scripts/build-release.js minor",
    "release:major": "node scripts/build-release.js major",
    "daemon": "node scripts/qqbot-poll-daemon.js",
    "daemon:auto": "node scripts/qqbot-poll-daemon.js --auto",
    "gateway": "node scripts/qqbot-gateway.js",
    "gateway:start": "node scripts/qqbot-gateway.js start",
    "gateway:start:auto": "node scripts/qqbot-gateway.js start --auto",
    "gateway:stop": "node scripts/qqbot-gateway.js stop",
    "gateway:status": "node scripts/qqbot-gateway.js status",
    "hooks": "node scripts/qqbot-hooks.js",
    "hooks:list": "node scripts/qqbot-hooks.js list",
    "hooks:add": "node scripts/qqbot-hooks.js add",
    "upgrade": "node scripts/qqbot-upgrade.js",
    "upgrade:rollback": "node scripts/qqbot-upgrade.js rollback",
    "upgrade:backups": "node scripts/qqbot-upgrade.js list-backups"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^16.4.0",
    "mpg123-decoder": "^1.0.3",
    "silk-wasm": "^3.7.1",
    "ws": "^8.18.0"
  },
  "bundledDependencies": [
    "mpg123-decoder",
    "silk-wasm",
    "ws"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "clawdbot": "*",
    "moltbot": "*",
    "openclaw": "*"
  },
  "homepage": "https://github.com/fuzhibo/qqbot-claudecode-skill",
  "bundleDependencies": [
    "mpg123-decoder",
    "silk-wasm",
    "ws"
  ]
}
