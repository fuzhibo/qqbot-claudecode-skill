{
  "name": "qqbot-mcp",
  "version": "1.16.0",
  "description": "QQ Bot MCP integration for Claude Code - send messages, files, and receive tasks from QQ. Supports Channel mode (v2.1.80+) with real-time push and permission relay.",
  "author": {
    "name": "fuzhibo",
    "email": ""
  },
  "homepage": "https://github.com/fuzhibo/qqbot-claudecode-skill",
  "repository": "https://github.com/fuzhibo/qqbot-claudecode-skill",
  "license": "MIT",
  "keywords": [
    "qq",
    "bot",
    "mcp",
    "messaging",
    "chinese",
    "channel",
    "real-time"
  ],
  "commands": [
    "./commands/"
  ],
  "mcpServers": {
    "qqbot": {
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/dist/mcp/index.js"
      ],
      "env": {
        "QQBOT_APP_ID": "${QQBOT_APP_ID}",
        "QQBOT_CLIENT_SECRET": "${QQBOT_CLIENT_SECRET}",
        "QQBOT_IMAGE_SERVER_BASE_URL": "${QQBOT_IMAGE_SERVER_BASE_URL}",
        "QQBOT_CHANNEL_MODE": "${QQBOT_CHANNEL_MODE:-auto}"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/check-channel-support.js 2>/dev/null || echo '\\n⚠️  QQ Bot: Channel 模式不可用，已回退到 MCP Tools 模式\\n'"
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/setup-wizard.js --check 2>/dev/null || echo '\\n🤖 QQ Bot MCP: 尚未配置，请运行 /qqbot-setup 或设置 QQBOT_APP_ID/QQBOT_CLIENT_SECRET 环境变量\\n'"
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/qqbot-upgrade.js 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
